DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tuna?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/tuna?schema=public"
NEXTAUTH_SECRET="replace-this-with-a-long-random-secret-value"
NEXTAUTH_URL="http://localhost:3000"
APP_ENV="development"
ENABLE_DEMO_SEED="true"
RATE_LIMIT_LOGIN_MAX="5"
RATE_LIMIT_LOGIN_WINDOW_MS="600000"
RATE_LIMIT_MUTATION_MAX="60"
RATE_LIMIT_MUTATION_WINDOW_MS="60000"
# Vercel preview tip:
# NEXTAUTH_URL staging preview icin zorunlu degildir, VERCEL_BRANCH_URL veya VERCEL_URL varsa otomatik turetilir.
